// This is the runtime for decaf, it is a simple class that includes,
// some core functionality required by user programs.
class Runtime {
  // --- Declarations ---
  // The heap pointer.
  int HeapPointer;
  // The size of a page.
  int PageSize;
  // --- Initialization ---
  void Main() {
    this.HeapPointer = 0;
    this.PageSize = 65536;
  }
  // --- Allocation ---
  // An extremely simple implementation of malloc using a bump allocator
  int malloc(int byteSize) {
    // --- Declarations ---
    // The byteSize after we have aligned it to 4 bytes
    int alignedByteSize;
    // The pointer to the allocated block itself
    int pointer;
    // The pointer to the end of the allocated block
    int end;
    // The number of pages returned by `@wasm.memory.size`
    int pageCount;
    // -- Implementation ---
    // Align the byteSize to 4 bytes
    alignedByteSize = (byteSize + 3) & ~3;
    // Set the pointer value to the current heap end
    pointer = this.HeapPointer;
    // Determine the end of the block
    end = pointer + alignedByteSize;
    // Fetch the page count
    pageCount = callout("@wasm.memory.size");
    // Determine if the program has enough memory
    if (end <= (pageCount * PageSize)) {
      // Grow the memory if we need
      callout("@wasm.memory.grow", 1);
    }
    // Bump the heap pointer
    this.HeapPointer = end;
    // Return the block pointer
    return pointer;
  }
  // A function similar to malloc but clears the block to 0
  int calloc(int byteSize) {
    // The block pointer
    int pointer;
    // Malloc the block
    pointer = this.malloc(byteSize);
    // Zero the region in case we used it before
    callout("@wasm.memory.fill", pointer, 0, byteSize);
    // Return the block pointer
    return pointer;
  }
}